<Window x:Class="CybersecurityAwarenessBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="650"
        Width="900"
        Background="Black"
        Loaded="Window_Loaded">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock
            Text="CYBERSECURITY AWARENESS BOT"
            FontSize="26"
            FontWeight="Bold"
            Foreground="Cyan"
            HorizontalAlignment="Center"
            Margin="0,0,0,10"/>

        <!-- ASCII ART -->
        <TextBox
            x:Name="AsciiArtBox"
            Grid.Row="1"
            FontFamily="Consolas"
            FontSize="12"
            Foreground="Lime"
            Background="Black"
            BorderBrush="Cyan"
            IsReadOnly="True"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto"/>

        <!-- CHAT -->
        <TextBox
            x:Name="ChatBox"
            Grid.Row="2"
            Margin="0,10,0,10"
            FontFamily="Consolas"
            FontSize="14"
            Foreground="White"
            Background="#111111"
            BorderBrush="Cyan"
            IsReadOnly="True"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto"/>

        <!-- INPUT AREA -->
        <StackPanel
            Grid.Row="3"
            Orientation="Horizontal">

            <TextBox
                x:Name="InputBox"
                Width="600"
                Height="35"
                FontSize="14"
                Margin="0,0,10,0"/>

            <Button
                Content="Send"
                Width="100"
                Height="35"
                Background="Cyan"
                Click="SendButton_Click"/>

            <Button
                Content="Exit"
                Width="100"
                Height="35"
                Margin="10,0,0,0"
                Background="Red"
                Click="ExitButton_Click"/>
        </StackPanel>

    </Grid>
</Window>
 